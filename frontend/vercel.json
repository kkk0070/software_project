{
    "version": 2,
    "builds": [
        {
            "src": "build/web/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/build/web/assets/$1"
        },
        {
            "src": "/canvaskit/(.*)",
            "dest": "/build/web/canvaskit/$1"
        },
        {
            "src": "/icons/(.*)",
            "dest": "/build/web/icons/$1"
        },
        {
            "src": "/(flutter\\.js|flutter_bootstrap\\.js|flutter_service_worker\\.js|main\\.dart\\.js|manifest\\.json|version\\.json|favicon\\.png)(.*)",
            "dest": "/build/web/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/build/web/index.html"
        }
    ]
}